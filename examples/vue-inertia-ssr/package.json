{
  "name": "vue-inertia-ssr",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build && npm run build:ssr",
    "build:ssr": "vite build --ssr resources/ssr.ts --outDir bootstrap/ssr",
    "start:ssr": "node bootstrap/ssr/ssr.js",
    "dev:ssr": "npm run build:ssr && node bootstrap/ssr/ssr.js",
    "preview": "vite preview",
    "serve": "vite preview",
    "generate-types": "openapi-ts --config openapi-ts.config.ts"
  },
  "dependencies": {
    "@inertiajs/vue3": "3.6.0",
    "@vue/server-renderer": "3.5.39",
    "vue": "3.5.39",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "litestar-vite-plugin": "file:../..",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vue-tsc": "3.3.6"
  }
}
