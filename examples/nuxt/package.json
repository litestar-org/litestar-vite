{
  "name": "nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "serve": "node .output/server/index.mjs",
    "watch": "npm run serve",
    "postinstall": "nuxt prepare",
    "typecheck": "vue-tsc -b --noEmit",
    "generate-types": "openapi-ts --config openapi-ts.config.ts"
  },
  "dependencies": {
    "nuxt": "4.4.2",
    "vue": "3.5.38",
    "zod": "4.4.3"
  },
  "overrides": {
    "@vitejs/devtools": "0.3.4"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.98.2",
    "@tailwindcss/vite": "4.2.4",
    "litestar-vite-plugin": "file:../..",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vue-tsc": "3.3.5"
  }
}
