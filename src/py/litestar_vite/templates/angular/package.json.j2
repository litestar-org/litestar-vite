{
  "name": "{{ project_name }}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite preview"{% if generate_client %},
    "generate-types": "openapi-ts"{% endif %}
  },
  "dependencies": {
    "@angular/animations": "{{ package_version('@angular/animations') }}",
    "@angular/common": "{{ package_version('@angular/common') }}",
    "@angular/compiler": "{{ package_version('@angular/compiler') }}",
    "@angular/core": "{{ package_version('@angular/core') }}",
    "@angular/forms": "{{ package_version('@angular/forms') }}",
    "@angular/platform-browser": "{{ package_version('@angular/platform-browser') }}",
    "rxjs": "{{ package_version('rxjs') }}"{% if generate_zod %},
    "zod": "{{ package_version('zod') }}"{% endif %}
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "{{ package_version('@analogjs/vite-plugin-angular') }}",
    "@angular/build": "{{ package_version('@angular/build') }}",
    "@angular/compiler-cli": "{{ package_version('@angular/compiler-cli') }}",
    "@angular/platform-browser-dynamic": "{{ package_version('@angular/platform-browser-dynamic') }}",
{% if use_tailwind %}    "@tailwindcss/vite": "{{ package_version('@tailwindcss/vite') }}",
{% endif %}{% if generate_client %}    "@hey-api/openapi-ts": "{{ package_version('@hey-api/openapi-ts') }}",
{% endif %}    "@types/node": "{{ package_version('@types/node') }}",
    "litestar-vite-plugin": "{{ package_version('litestar-vite-plugin') }}",
{% if use_tailwind %}    "tailwindcss": "{{ package_version('tailwindcss') }}",
{% endif %}    "typescript": "{{ package_version('typescript') }}",
    "vite": "{{ package_version('vite') }}"
  }
}
