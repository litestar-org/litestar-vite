{
  "name": "{{ project_name }}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "check": "astro check",
    "typecheck": "astro check",
    "preview": "astro preview",
    "serve": "astro preview",
    "watch": "npm run serve",
    "update": "npm update"{% if generate_client %},
    "generate-types": "openapi-ts --config openapi-ts.config.ts"{% endif %}
  },
  "dependencies": {
    "astro": "{{ package_version('astro') }}"{% if generate_zod %},
    "zod": "{{ package_version('zod') }}"{% endif %}
  },
  "devDependencies": {
{% if generate_client %}    "@hey-api/openapi-ts": "{{ package_version('@hey-api/openapi-ts') }}",
{% endif %}{% if use_tailwind %}    "@tailwindcss/postcss": "{{ package_version('@tailwindcss/postcss') }}",
{% endif %}    "litestar-vite-plugin": "{{ package_version('litestar-vite-plugin') }}",
{% if use_tailwind %}    "tailwindcss": "{{ package_version('tailwindcss') }}",
{% endif %}    "typescript": "{{ package_version('typescript') }}",
    "vite": "{{ package_version('vite') }}"
  }
}
