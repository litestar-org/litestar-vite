{
  "name": "{{ project_name }}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "check": "astro check",
    "typecheck": "astro check",
    "preview": "astro preview",
    "serve": "astro preview",
    "watch": "npm run serve",
    "update": "npm update"{% if generate_client %},
    "generate-types": "openapi-ts --config openapi-ts.config.ts"{% endif %}
  },
  "dependencies": {
    "astro": "5.18.0"{% if generate_zod %},
    "zod": "4.3.6"{% endif %}
  },
  "devDependencies": {
{% if generate_client %}    "@hey-api/openapi-ts": "0.94.0",
{% endif %}{% if use_tailwind %}    "@tailwindcss/vite": "4.2.2",
{% endif %}    "litestar-vite-plugin": "{{ package_version('litestar-vite-plugin') }}",
{% if use_tailwind %}    "tailwindcss": "4.2.2",
{% endif %}    "typescript": "5.9.3",
    "vite": "8.0.1"
  }
}
