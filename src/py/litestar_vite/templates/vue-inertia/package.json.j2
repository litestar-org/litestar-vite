{
  "name": "{{ project_name }}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
{% if enable_ssr %}
    "build": "vue-tsc -b && vite build && vite build --ssr {{ resource_dir }}/ssr.ts",
{% else %}
    "build": "vue-tsc -b && vite build",
{% endif %}
    "preview": "vite preview",
{% if enable_ssr %}
    "serve": "NODE_ENV=production node {{ resource_dir }}/bootstrap/ssr/ssr.js",
{% else %}
    "serve": "vite preview",
{% endif %}
    "watch": "npm run serve",
    "update": "npm update"{% if generate_client %},
    "generate-types": "openapi-ts"{% endif %}
  },
  "dependencies": {
    "@inertiajs/vue3": "2.3.17",
    "vue": "3.5.29"{% if generate_zod or generate_client or enable_ssr %},{% endif %}
{%- if generate_client %}
    "axios": "1.13.6"{% if generate_zod or enable_ssr %},{% endif %}
{%- endif %}
{%- if generate_zod %}
    "zod": "4.3.6"{% if enable_ssr %},{% endif %}
{%- endif %}
{%- if enable_ssr %}
    "@vue/server-renderer": "3.5.29"
{%- endif %}
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/tsconfig": "0.9.0",
    "typescript": "5.9.3",
    "vue-tsc": "3.2.5",
{%- if use_tailwind %}
    "@tailwindcss/vite": "4.2.1",
    "tailwindcss": "4.2.1",
{%- endif %}
{%- if generate_client %}
    "@hey-api/openapi-ts": "0.94.0",
{%- endif %}
    "litestar-vite-plugin": "0.18.4",
    "vite": "7.3.1"
  }
}
