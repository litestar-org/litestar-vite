{
  "name": "{{ project_name }}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "node build",
    "watch": "npm run serve",
    "prepare": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"{% if enable_types %},
    "generate-types": "openapi-ts --config openapi-ts.config.ts"{% endif %}
  },
  "dependencies": {
    "@sveltejs/kit": "2.53.4",
    "svelte": "5.53.7"{% if generate_zod %},
    "zod": "4.3.6"{% endif %}
  },
  "devDependencies": {
{%- if enable_types %}
    "@hey-api/openapi-ts": "0.94.0",
{%- endif %}
    "@sveltejs/adapter-node": "5.5.4",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
{%- if use_tailwind %}
    "@tailwindcss/vite": "4.2.1",
{%- endif %}
    "litestar-vite-plugin": "{{ package_version('litestar-vite-plugin') }}",
    "svelte-check": "4.4.4",
{%- if use_tailwind %}
    "tailwindcss": "4.2.1",
{%- endif %}
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
