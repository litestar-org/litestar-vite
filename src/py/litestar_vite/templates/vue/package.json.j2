{
  "name": "{{ project_name }}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "serve": "vite preview",
    "watch": "npm run serve",
    "update": "npm update"{% if generate_client %},
    "generate-types": "openapi-ts"{% endif %}
  },
  "dependencies": {
    "vue": "3.5.29"{% if generate_client or generate_zod %},{% endif %}
{%- if generate_client %}
    "axios": "1.13.6"{% if generate_zod %},{% endif %}
{%- endif %}
{%- if generate_zod %}
    "zod": "4.3.6"
{%- endif %}
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/tsconfig": "0.9.0",
    "typescript": "5.9.3",
    "vue-tsc": "3.2.5",
{%- if use_tailwind %}
    "@tailwindcss/vite": "4.2.1",
    "tailwindcss": "4.2.1",
{%- endif %}
{%- if generate_client %}
    "@hey-api/openapi-ts": "0.94.0",
{%- endif %}
    "litestar-vite-plugin": "0.18.4",
    "vite": "8.0.1"
  }
}
